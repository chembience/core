#!/bin/bash

# This script initializes the FastAPI application.
# Since we are using SQLAlchemy with metadata.create_all(bind=engine) in main.py,
# a simple start of the container will handle basic table creation.

if [ -z "$(docker compose ps fastapi -q 2>/dev/null)" ]; then
    echo "FastAPI container is not running. Starting it..."
    docker compose up -d fastapi
fi

echo "FastAPI initialization complete (Basic tables are created on startup)."
