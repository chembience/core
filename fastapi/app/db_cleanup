#!/bin/bash

# Load environment variables from .env file
if [ -f .env ]; then
  set -o allexport
  source .env
  set +o allexport
else
  echo ".env file not found!"
  exit 1
fi

# Set defaults if not defined in .env
POSTGRES_USER=${POSTGRES_USER:-chembience}
POSTGRES_NAME=${POSTGRES_NAME:-chembience}
POSTGRES_HOST=${POSTGRES_HOST:-postgres}
POSTGRES_INTERNAL_PORT=${POSTGRES_INTERNAL_PORT:-5432}

# Identify the project name to find the correct container
PROJECT_NAME=$(basename "$(pwd)")

# Check if the container is running
CONTAINER_ID=$(docker ps -q -f "name=${PROJECT_NAME}-postgres-1" -f "status=running")

if [ -z "$CONTAINER_ID" ]; then
    # Fallback to just "postgres" if project-specific name not found
    CONTAINER_ID=$(docker ps -q -f "name=postgres" -f "status=running")
fi

if [ -z "$CONTAINER_ID" ]; then
    echo "❌ Error: PostgreSQL container is not running."
    echo "Please start the services with 'docker-compose up -d' first."
    exit 1
fi

echo "🧹 Cleaning up database '$POSTGRES_NAME'..."
echo "⚠️  This will drop and recreate the database. Are you sure? (y/N)"
read -r response
if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
    docker exec -e PGPASSWORD="$POSTGRES_PASSWORD" "$CONTAINER_ID" psql -p "$POSTGRES_INTERNAL_PORT" -U "$POSTGRES_USER" -d postgres -c "DROP DATABASE IF EXISTS \"$POSTGRES_NAME\" WITH (FORCE);"
    docker exec -e PGPASSWORD="$POSTGRES_PASSWORD" "$CONTAINER_ID" psql -p "$POSTGRES_INTERNAL_PORT" -U "$POSTGRES_USER" -d postgres -c "CREATE DATABASE \"$POSTGRES_NAME\";"
    docker exec -e PGPASSWORD="$POSTGRES_PASSWORD" "$CONTAINER_ID" psql -p "$POSTGRES_INTERNAL_PORT" -U "$POSTGRES_USER" -d "$POSTGRES_NAME" -c "CREATE EXTENSION IF NOT EXISTS rdkit;"
    
    if [ $? -eq 0 ]; then
        echo "✅ Database '$POSTGRES_NAME' has been cleaned up (dropped and recreated)."
    else
        echo "❌ Error: Cleanup failed."
        exit 1
    fi
else
    echo "Cleanup cancelled."
fi
