#!/bin/bash

# Load environment variables from .env file
if [ -f .env ]; then
  set -o allexport
  source .env
  set +o allexport
else
  echo ".env file not found!"
  exit 1
fi

# Determine what to do
SKIP_CORE=false
CLEANUP_IMAGES=false
CUSTOM_DIR=""
SILENT=false
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --images|-i)
      CLEANUP_IMAGES=true
      shift
      ;;
    --no-core-images|-c)
      CLEANUP_IMAGES=true
      SKIP_CORE=true
      shift
      ;;
    --silent|-s)
      SILENT=true
      shift
      ;;
    --dir|-d)
      CUSTOM_DIR="$2"
      shift 2
      ;;
    -*)
      echo "Unknown argument: $1"
      echo "Supported: --images, -i, --no-core-images, -c, --dir, -d, --silent, -s"
      exit 2
      ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

APP_ID="${POSITIONAL_ARGS[0]:-}"

if [ -n "$CUSTOM_DIR" ]; then
  export APP_HOME="$CUSTOM_DIR/${APP_ID:-app}"
else
  export APP_HOME="$HOME/${APP_ID:-app}"
fi
export APP_NAME="${APP_ID:-app}"

# Expand APP_HOME if it starts with ~
if [[ "$APP_HOME" == "~"* ]]; then
  APP_HOME="${APP_HOME/#\~/$HOME}"
fi

# If running in silent mode, suppress standard output (keep stderr visible)
if [ "$SILENT" = true ]; then
  exec 1>/dev/null
fi

# Function to check if any chembience-related containers are running
check_running_chembience() {
  # Look for containers using chembience images or having chembience in the name
  RUNNING=$(docker ps --format '{{.Image}}' | grep '^chembience/')
  if [ -n "$RUNNING" ]; then
    return 0 # Running containers found
  else
    return 1 # No running containers found
  fi
}

# Function to remove all chembience containers and images
cleanup_all_chembience() {
  echo "🔍 Checking for running Chembience apps..."
  if check_running_chembience; then
    echo "❌ Error: Chembience-related containers are currently running."
    echo "Please stop all Chembience applications before removing images."
    docker ps --filter "ancestor=chembience" --format "table {{.ID}}\t{{.Image}}\t{{.Status}}\t{{.Names}}" | grep 'chembience'
    exit 1
  fi

  echo "🗑️ Removing all Chembience-related containers (stopped)..."
  # Remove stopped containers that have 'chembience' in their name or image
  STOPPED_CONTAINERS=$(docker ps -a --format '{{.ID}} {{.Image}}' | grep 'chembience' | awk '{print $1}')
  if [ -n "$STOPPED_CONTAINERS" ]; then
    echo "$STOPPED_CONTAINERS" | xargs -r docker rm >/dev/null 2>&1
  fi

  if [ "$SKIP_CORE" = true ]; then
    echo "🗑️ Removing Chembience app images (sparing core images)..."
    # Exclude: core-rdkit, core-rdkit-postgres, and core-django
    # Note: we use grep -v to exclude the core images
    IMAGES=$(docker images --format '{{.Repository}}:{{.Tag}} {{.ID}}' | \
      grep '^chembience/' | \
      grep -v 'chembience/core-rdkit:' | \
      grep -v 'chembience/core-rdkit-postgres:' | \
      grep -v 'chembience/core-django:' | \
      grep -v 'chembience/core-jupyter:' | \
      awk '{print $2}')
  else
    echo "🗑️ Removing all Chembience-related images..."
    IMAGES=$(docker images --format '{{.Repository}}:{{.Tag}} {{.ID}}' | grep '^chembience/' | awk '{print $2}')
  fi

  if [ -n "$IMAGES" ]; then
    echo "$IMAGES" | xargs -r docker rmi -f >/dev/null 2>&1
  else
    echo "ℹ️ No matching Chembience images found."
  fi
}

# Function to check if it looks like a chembience app
is_chembience_app() {
  if [ ! -d "$APP_HOME" ]; then
    return 1
  fi
  # Check for specific files that define a chembience app
  # We now check for .chembience which contains metadata
  if [ -f "$APP_HOME/.chembience" ] && [ -f "$APP_HOME/docker-compose.yml" ]; then
    return 0
  else
    return 1
  fi
}

# Function to remove the application directory
remove_apps() {
  if [ -d "$APP_HOME" ]; then
    if ! is_chembience_app; then
      echo "❌ Error: $APP_HOME does not look like a chembience app (missing .chembience or docker-compose.yml)."
      echo "Aborting removal of $APP_HOME."
      return 1
    fi

    if [ "$SILENT" != true ]; then
      echo "⚠️  WARNING: You are about to delete the following directory and all its contents:"
      echo "   - $APP_HOME"
      echo "   - $APP_HOME/postgres (Database data)"
      read -p "Are you sure you want to proceed? (y/N): " confirm
      if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        return 1
      fi
    fi

    if [ -f "$APP_HOME/docker-compose.yml" ]; then
      echo "🛑 Stopping and removing containers in $APP_HOME..."
      if [ "$SILENT" = true ]; then
        (cd "$APP_HOME" && APP_NAME="$APP_NAME" docker compose down >/dev/null 2>&1)
      else
        (cd "$APP_HOME" && APP_NAME="$APP_NAME" docker compose down)
      fi
    fi
    echo "🗑️ Removing $APP_HOME using Docker..."
    if [ "$SILENT" = true ]; then
      docker run --rm -v "$(dirname "$APP_HOME")":/cleanup alpine rm -rf "/cleanup/$(basename "$APP_HOME")" >/dev/null 2>&1
    else
      docker run --rm -v "$(dirname "$APP_HOME")":/cleanup alpine rm -rf "/cleanup/$(basename "$APP_HOME")"
    fi
  else
    echo "ℹ️ $APP_HOME does not exist or is not a directory."
    return 1
  fi
}

# Function to remove the images for a specific app
remove_app_images() {
  # Check if CHEMBIENCE_VERSION is set in the .env file
  if [ -z "$CHEMBIENCE_VERSION" ]; then
    echo "⚠️ CHEMBIENCE_VERSION is not set in the .env file. Skipping image removal."
    return
  fi

  # Fixed name pattern
  NAME_PATTERN="^chembience/"
  
  # Find matching images (excluding generic base images)
  # Patterns: ^chembience/ (all our images) AND APP_NAME (app specific suffix)
  # This ensures we don't delete generic images like chembience/core-rdkit or chembience/core-rdkit-postgres
  IMAGES=$(docker images --format '{{.Repository}}:{{.Tag}} {{.ID}}' | grep -E -e "$NAME_PATTERN" | grep -E -e "$APP_NAME")

  if [ -z "$IMAGES" ]; then
    echo "ℹ️ No matching images found for app '$APP_ID' (pattern '$NAME_PATTERN' and '$APP_NAME')"
    return
  fi

  echo "🗑️ Removing matching images for app '$APP_ID':"
  echo "$IMAGES"

  # Remove each matched image
  echo "$IMAGES" | awk '{print $2}' | xargs -r docker rmi -f >/dev/null 2>&1
}

# Execution sequence
# 1. App removal (if app name provided)
if [ -n "$APP_ID" ]; then
  if remove_apps; then
    remove_app_images
  fi
elif [ "$CLEANUP_IMAGES" = false ]; then
    # Default behavior if no app name and no -i: try to remove default 'app'
    APP_ID="app"
    export APP_NAME="-app"
    # Re-evaluate APP_HOME for default 'app'
    if [ -n "$CUSTOM_DIR" ]; then
      export APP_HOME="$CUSTOM_DIR/app"
    else
      export APP_HOME="$HOME/app"
    fi

    if remove_apps; then
      remove_app_images
    fi
fi

# 2. Global image cleanup (if -i or -c provided)
if [ "$CLEANUP_IMAGES" = true ]; then
  cleanup_all_chembience
fi
