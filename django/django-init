#!/bin/bash

# This script initializes the Django application by running migrations
# and creating a superuser if it doesn't exist.

# Check if the Django container is running
if [ -z "$(docker compose ps django -q 2>/dev/null)" ]; then
    echo "Django container is not running. Starting it..."
    docker compose up -d django
    # Wait for the container to be ready (optional but recommended)
    # We can rely on the docker-manage-py script to handle connectivity
fi

./django-manage-py makemigrations
./django-manage-py migrate
./django-manage-py createsuperuser --noinput || true
./django-manage-py collectstatic --noinput || true
./django-manage-py test

# --- Final info: print the web URL ---
# Load .env if present to get the connection port; fall back to defaults
if [ -f .env ]; then
  set -o allexport
  source .env
  set +o allexport
fi

DJANGO_CONNECTION_PORT=${DJANGO_CONNECTION_PORT:-8001}
DJANGO_VIRTUAL_HOSTNAME=${DJANGO_VIRTUAL_HOSTNAME:-localhost}

echo
echo "🌐 Django is available at: http://${DJANGO_VIRTUAL_HOSTNAME}:${DJANGO_CONNECTION_PORT}/"
echo "   Admin (once superuser is active): http://${DJANGO_VIRTUAL_HOSTNAME}:${DJANGO_CONNECTION_PORT}/admin/"