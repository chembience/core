#!/bin/bash
set -euo pipefail

# Create .env once from template; don't overwrite local settings
if [ ! -f .env ]; then
  cp .env.example .env
  echo "Created .env from template (.env.example)."
else
  # Check if .env.example is newer and different
  if [ .env.example -nt .env ] && ! cmp -s .env.example .env; then
    echo "⚠️  The template .env.example is newer than your current .env and contains changes."
    if [ "${NO_PROMPT:-false}" = true ]; then
      echo "⏩ Non-interactive mode: leaving your existing .env unchanged."
    else
      read -p "Do you want to overwrite your .env with the new template? (y/N) " -n 1 -r
      echo
      if [[ $REPLY =~ ^[Yy]$ ]]; then
        cp .env.example .env
        echo "✅ .env updated from template."
      else
        echo "⏩ Skipping .env update."
      fi
    fi
  fi
fi

# Load environment variables from .env
set -o allexport
source .env
set +o allexport

# Check if the published Postgres host port is already in use
PORT_TO_CHECK="${POSTGRES_HOST_PORT:-${POSTGRES_PORT:-5433}}"
if netstat -tuln | grep -q ":$PORT_TO_CHECK "; then
  echo "❌ Error: Postgres port $PORT_TO_CHECK is already in use."
  echo "Please stop the service using this port or change POSTGRES_HOST_PORT in .env"
  exit 1
fi

# Match container UID/GID to current user (WSL2/macOS/Linux)
export CHEMBIENCE_UID="${CHEMBIENCE_UID:-$(id -u)}"
export CHEMBIENCE_GID="${CHEMBIENCE_GID:-$(id -g)}"

# Positional arguments and flags
BUILD_FLAGS=()
QUIT_AFTER_SETUP=true
POSITIONAL_ARGS=()
NO_PROMPT=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-cache|--pull|--progress=*)
      BUILD_FLAGS+=("$1")
      shift
      ;;
    --no-quit)
      QUIT_AFTER_SETUP=false
      shift
      ;;
    --no-prompt|-y)
      NO_PROMPT=true
      export NO_PROMPT
      shift
      ;;
    --dir|-d)
      CUSTOM_DIR="$2"
      shift 2
      ;;
    -*)
      echo "Unknown argument: $1"
      echo "Supported: --no-cache, --pull, --progress=plain, --no-quit, --no-prompt|-y, --dir|-d"
      exit 2
      ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

TYPE="${POSITIONAL_ARGS[0]:-django}"
TARGET="${POSITIONAL_ARGS[1]:-app}"

if [ "$TYPE" != "django" ] && [ "$TYPE" != "rdkit" ] && [ "$TYPE" != "fastapi" ] && [ "$TYPE" != "jupyter" ]; then
  echo "Error: Only 'django', 'rdkit', 'fastapi' and 'jupyter' types are currently supported."
  exit 1
fi

export APP_ID="$TARGET"
export APP_NAME="$TARGET"
if [ -n "${CUSTOM_DIR:-}" ]; then
  export APP_HOME="$CUSTOM_DIR/$TARGET"
else
  export APP_HOME="$HOME/$TARGET"
fi

cleanup() {
  echo "🧹 Cleaning up containers..."
  if [ "$QUIT_AFTER_SETUP" = true ]; then
    # Keep volumes if we just did a setup
    APP_NAME="$APP_NAME" docker compose down
  else
    APP_NAME="$APP_NAME" docker compose down --volumes
  fi
}
trap cleanup EXIT

# Expand APP_HOME if it starts with ~
if [[ "$APP_HOME" == "~"* ]]; then
  APP_HOME="${APP_HOME/#\~/$HOME}"
fi

# Check if target directory already exists
if [ -d "$APP_HOME" ]; then
  echo "❌ Error: Target directory '$APP_HOME' already exists."
  echo "Please use a different target name or remove the existing directory first."
  exit 1
fi

# Ensure APP_HOME exists locally so Docker doesn't create it as root
mkdir -p "$APP_HOME"
APP_HOME=$(cd "$APP_HOME" && pwd)
export APP_HOME

# posix shell variable expansion for JUPYTER_CONNECTION_PORT if not set
export JUPYTER_CONNECTION_PORT="${JUPYTER_CONNECTION_PORT:-8888}"

echo "📂 Using APP_HOME: $APP_HOME for target: $TARGET (type: $TYPE)"

# Check if the application port is already in use
if [ "$TYPE" = "django" ]; then
    APP_PORT="${DJANGO_CONNECTION_PORT:-8001}"
elif [ "$TYPE" = "fastapi" ]; then
    APP_PORT="${FASTAPI_CONNECTION_PORT:-8002}"
elif [ "$TYPE" = "jupyter" ]; then
    APP_PORT="${JUPYTER_CONNECTION_PORT:-8888}"
else
    APP_PORT=""
fi

if [ -n "$APP_PORT" ]; then
    if netstat -tuln | grep -q ":$APP_PORT "; then
        echo "❌ Error: Application port $APP_PORT (type: $TYPE) is already in use."
        echo "Please stop the service using this port or change the corresponding *_CONNECTION_PORT in .env"
        exit 1
    fi
fi

# Build base images first, then images that depend on them
if [ "$TYPE" = "rdkit" ]; then
    docker compose build "${BUILD_FLAGS[@]}" rdkit postgres
    APP_NAME="$APP_NAME" docker compose build "${BUILD_FLAGS[@]}" rdkit-app
elif [ "$TYPE" = "fastapi" ]; then
    docker compose build "${BUILD_FLAGS[@]}" rdkit postgres
    APP_NAME="$APP_NAME" docker compose build "${BUILD_FLAGS[@]}" fastapi
elif [ "$TYPE" = "jupyter" ]; then
    docker compose build "${BUILD_FLAGS[@]}" rdkit postgres
    APP_NAME="$APP_NAME" docker compose build "${BUILD_FLAGS[@]}" jupyter
else
    docker compose build "${BUILD_FLAGS[@]}" rdkit postgres
    APP_NAME="$APP_NAME" docker compose build "${BUILD_FLAGS[@]}" django
fi

if [ "$QUIT_AFTER_SETUP" = true ]; then
  echo "🚀 Starting containers in setup mode (will quit once healthy)..."
  if [ "$TYPE" = "rdkit" ]; then
    APP_NAME="$APP_NAME" docker compose up --wait rdkit-app postgres
  elif [ "$TYPE" = "fastapi" ]; then
    APP_NAME="$APP_NAME" docker compose up --wait fastapi postgres
  elif [ "$TYPE" = "jupyter" ]; then
    APP_NAME="$APP_NAME" docker compose up --wait jupyter postgres
  else
    APP_NAME="$APP_NAME" docker compose up --wait django postgres
  fi
  echo "✅ Everything is setup. Exiting..."
else
  if [ "$TYPE" = "rdkit" ]; then
    APP_NAME="$APP_NAME" docker compose up --abort-on-container-exit rdkit-app postgres
  elif [ "$TYPE" = "fastapi" ]; then
    APP_NAME="$APP_NAME" docker compose up --abort-on-container-exit fastapi postgres
  elif [ "$TYPE" = "jupyter" ]; then
    APP_NAME="$APP_NAME" docker compose up --abort-on-container-exit jupyter postgres
  else
    APP_NAME="$APP_NAME" docker compose up --abort-on-container-exit django postgres
  fi
fi