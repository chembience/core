#!/bin/bash
set -euo pipefail

# Create .env once from template; don't overwrite local settings
if [ ! -f .env ]; then
  cp .env.example .env
  echo "Created .env from template (.env.example)."
fi

# Load environment variables from .env
set -o allexport
source .env
set +o allexport

# Match container UID/GID to current user (WSL2/macOS/Linux)
export CHEMBIENCE_UID="${CHEMBIENCE_UID:-$(id -u)}"
export CHEMBIENCE_GID="${CHEMBIENCE_GID:-$(id -g)}"

# Positional arguments and flags
BUILD_FLAGS=()
QUIT_AFTER_SETUP=true
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-cache|--pull|--progress=*)
      BUILD_FLAGS+=("$1")
      shift
      ;;
    --no-quit)
      QUIT_AFTER_SETUP=false
      shift
      ;;
    --dir|-d)
      CUSTOM_DIR="$2"
      shift 2
      ;;
    -*)
      echo "Unknown argument: $1"
      echo "Supported: --no-cache, --pull, --progress=plain, --no-quit, --dir, -d"
      exit 2
      ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

TYPE="${POSITIONAL_ARGS[0]:-django}"
TARGET="${POSITIONAL_ARGS[1]:-app}"

if [ "$TYPE" != "django" ] && [ "$TYPE" != "rdkit" ]; then
  echo "Error: Only 'django' and 'rdkit' types are currently supported."
  exit 1
fi

export APP_ID="$TARGET"
export APP_NAME="-$TARGET"
if [ -n "${CUSTOM_DIR:-}" ]; then
  export APP_HOME="$CUSTOM_DIR/$TARGET"
else
  export APP_HOME="~/$TARGET"
fi

cleanup() {
  echo "🧹 Cleaning up containers..."
  if [ "$QUIT_AFTER_SETUP" = true ]; then
    # Keep volumes if we just did a setup
    APP_NAME="$APP_NAME" docker compose down
  else
    APP_NAME="$APP_NAME" docker compose down --volumes
  fi
}
trap cleanup EXIT

# Expand APP_HOME if it starts with ~
if [[ "$APP_HOME" == "~"* ]]; then
  APP_HOME="${APP_HOME/#\~/$HOME}"
fi

# Check if target directory already exists
if [ -d "$APP_HOME" ]; then
  echo "❌ Error: Target directory '$APP_HOME' already exists."
  echo "Please use a different target name or remove the existing directory first."
  exit 1
fi

# Ensure APP_HOME exists locally so Docker doesn't create it as root
mkdir -p "$APP_HOME"
export APP_HOME=$(cd "$APP_HOME" && pwd)

echo "📂 Using APP_HOME: $APP_HOME for target: $TARGET (type: $TYPE)"

# Build base images first, then images that depend on them
if [ "$TYPE" = "rdkit" ]; then
    docker compose build "${BUILD_FLAGS[@]}" rdkit postgres
    APP_NAME="$APP_NAME" docker compose build "${BUILD_FLAGS[@]}" rdkit-app
else
    docker compose build "${BUILD_FLAGS[@]}" rdkit postgres
    APP_NAME="$APP_NAME" docker compose build "${BUILD_FLAGS[@]}" django
fi

if [ "$QUIT_AFTER_SETUP" = true ]; then
  echo "🚀 Starting containers in setup mode (will quit once healthy)..."
  if [ "$TYPE" = "rdkit" ]; then
    APP_NAME="$APP_NAME" docker compose up --wait rdkit-app postgres
  else
    APP_NAME="$APP_NAME" docker compose up --wait django postgres
  fi
  echo "✅ Everything is setup. Exiting..."
else
  if [ "$TYPE" = "rdkit" ]; then
    APP_NAME="$APP_NAME" docker compose up --abort-on-container-exit rdkit-app postgres
  else
    APP_NAME="$APP_NAME" docker compose up --abort-on-container-exit django postgres
  fi
fi