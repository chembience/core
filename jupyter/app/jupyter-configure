#!/bin/bash
set -euo pipefail

# Usage:
#   ./jupyter-configure [--rebuild] [NEW_ENV_FILE]
#
# Two-phase workflow with a proposed new config file:
# 1) If NEW_ENV_FILE (default: ./.env.new) is missing, copy from .env and exit.
# 2) On second run, validate freshness, rotate DB password if changed, adopt new .env, and refresh Jupyter.

APP_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$APP_DIR"

REBUILD=0
NEW_ENV_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --rebuild) REBUILD=1; shift ;;
    -*) echo "Unknown option: $1" >&2; exit 2 ;;
    *) NEW_ENV_FILE="$1"; shift ;;
  esac
done

if [[ -z "${NEW_ENV_FILE}" ]]; then
  NEW_ENV_FILE=".env.new"
fi

if [[ ! -f .env ]]; then
  echo "Missing ./.env in $APP_DIR. Aborting." >&2
  exit 1
fi

mtime_epoch() { local f="$1"; if stat --version >/dev/null 2>&1; then stat -c %Y "$f"; else stat -f %m "$f"; fi; }
get_var_from_file() {
  local file="$1" var="$2" line val; line=$(grep -E "^${var}=" "$file" | tail -n1 || true)
  [[ -z "$line" ]] && { echo ""; return 0; }
  val="${line#*=}"; val="${val%\' }"; val="${val#\' }"; val="${val%\"}"; val="${val#\"}"; echo "$val"
}

if [[ ! -f "$NEW_ENV_FILE" ]]; then
  cp -f .env "$NEW_ENV_FILE"
  echo "🆕 Created '$NEW_ENV_FILE' as a copy of current .env."
  echo "➡️  Please edit '$NEW_ENV_FILE' with your desired new configuration, then re-run:"
  echo "    ./jupyter-configure [--rebuild] $NEW_ENV_FILE"
  exit 0
fi

now=$(date +%s); new_mtime=$(mtime_epoch "$NEW_ENV_FILE"); age=$(( now - new_mtime ))
if (( age > 300 )); then
  echo
  echo "============================================================"
  echo " STALE NEW CONFIG: '$NEW_ENV_FILE' (age=${age}s)"
  echo "------------------------------------------------------------"
  echo " For safety, confirm the file is up-to-date, then run:"
  echo "    touch '$NEW_ENV_FILE' && ./jupyter-configure [--rebuild] $NEW_ENV_FILE"
  echo "============================================================"
  exit 2
fi
env_mtime=$(mtime_epoch .env)
if (( new_mtime < env_mtime )); then
  echo
  echo "============================================================"
  echo " NEW CONFIG IS OLDER THAN CURRENT .env"
  echo "------------------------------------------------------------"
  echo " '$NEW_ENV_FILE' (mtime ${new_mtime}) < current .env (mtime ${env_mtime})."
  echo " Edit or 'touch' the new file, then rerun:"
  echo "    ./jupyter-configure [--rebuild] $NEW_ENV_FILE"
  echo "============================================================" >&2
  exit 2
fi

set -a; source ./.env; set +a
POSTGRES_USER="${POSTGRES_USER:-chembience}"
POSTGRES_NAME="${POSTGRES_NAME:-chembience}"
OLD_DB_PASSWORD="${POSTGRES_PASSWORD:-}"
NEW_DB_PASSWORD="$(get_var_from_file "$NEW_ENV_FILE" POSTGRES_PASSWORD)"

if [[ $REBUILD -eq 1 ]]; then
  echo "🔨 Rebuilding images (rdkit, postgres, jupyter)..."
  docker compose build --no-cache rdkit postgres jupyter
fi

echo "🚀 Starting Postgres and Jupyter..."
docker compose up -d postgres
docker compose up -d jupyter

echo "⏳ Waiting for Postgres to be healthy..."
for i in {1..30}; do
  if docker compose exec -T postgres pg_isready -U "$POSTGRES_USER" -d "$POSTGRES_NAME" -p 5432 >/dev/null 2>&1; then break; fi; sleep 2
done

if [[ -n "$NEW_DB_PASSWORD" && "$NEW_DB_PASSWORD" != "$OLD_DB_PASSWORD" ]]; then
  echo "🔐 Detected DB password change in '$NEW_ENV_FILE'. Rotating inside Postgres..."
  if [[ -z "$OLD_DB_PASSWORD" && -t 1 ]]; then read -r -s -p "Enter CURRENT (old) Postgres password for user $POSTGRES_USER: " OLD_DB_PASSWORD; echo; fi
  if [[ -z "$OLD_DB_PASSWORD" ]]; then echo "Cannot rotate DB password: old password unknown." >&2; exit 2; fi
  PGPASSWORD="$OLD_DB_PASSWORD" docker compose exec -T -e PGPASSWORD="$OLD_DB_PASSWORD" postgres psql -U "$POSTGRES_USER" -p 5432 -d "$POSTGRES_NAME" <<SQL
ALTER USER $POSTGRES_USER WITH PASSWORD '$NEW_DB_PASSWORD';
SQL
  echo "✅ Postgres password rotated."
fi

tmp_env=".env.next.$$"; cp -f "$NEW_ENV_FILE" "$tmp_env" && mv -f "$tmp_env" .env

echo "🔁 Refreshing Jupyter service to pick up latest .env..."
docker compose up -d --force-recreate jupyter

echo "🚀 Ensuring Jupyter (and Postgres) are up..."
docker compose up -d postgres jupyter

echo "✅ jupyter-configure completed."
