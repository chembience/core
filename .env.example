# Chembience Environment Variables Example

# --- General ---
CHEMBIENCE_VERSION=latest
APP_HOME=./app
# UID/GID for container users (if not set, the build script detects them automatically)
# CHEMBIENCE_UID=1000
# CHEMBIENCE_GID=1000

# --- Django ---
DJANGO_VIRTUAL_HOSTNAME=django.localhost,localhost
DJANGO_CONNECTION_PORT=8000
DJANGO_SECRET_KEY=generate-a-long-random-string-here
DJANGO_DEBUG=True
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-immediately

# --- PostgreSQL ---
POSTGRES_USER=chembience
POSTGRES_PASSWORD=secure-password-here
POSTGRES_NAME=chembience
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Build Configuration ---
# Set these to use alternative repositories/mirrors if default ones are slow or unreachable
APT_MIRROR=http://mirrors.ubuntu.com/mirrors.txt
CONDA_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/anaconda/cloud/
