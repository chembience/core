# Chembience Environment Variables Example

CONDA_PY=3.14
RDKIT_VERSION=2026.03.2

# --- General ---
CHEMBIENCE_VERSION=latest
APP_HOME=./app
# UID/GID for container users (if not set, the build script detects them automatically)
# CHEMBIENCE_UID=1000
# CHEMBIENCE_GID=1000

# --- Django ---
# Hostname for ALLOWED_HOSTS
DJANGO_VIRTUAL_HOSTNAME=django.localhost,localhost
# External port for Django (maps to internal 8000)
DJANGO_CONNECTION_PORT=8001
# Optional. If left empty/unset, the Django container will auto-generate a
# strong key on first init and persist it in the per-project .env (inside
# APP_HOME). Override here only if you want to inject a key from your own
# secrets store (Vault, Docker secrets, CI, etc.).
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-immediately

# --- FastAPI ---
# External port for FastAPI (maps to internal 8000)
FASTAPI_CONNECTION_PORT=8002

# --- Jupyter ---
# External port for JupyterLab (maps to internal 8888)
JUPYTER_CONNECTION_PORT=8888

# --- PostgreSQL ---
POSTGRES_USER=chembience
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_RUNNING
POSTGRES_NAME=chembience
POSTGRES_HOST=postgres
# Host-side published port for PostgreSQL (maps to in-container 5432).
# Inside the Docker network, services always connect on 5432 (POSTGRES_PORT is
# fixed to 5432 in docker-compose.yml). POSTGRES_HOST_PORT only affects the
# port exposed on the Docker host. POSTGRES_PORT (legacy name) is still
# accepted as a fallback for backwards compatibility.
POSTGRES_HOST_PORT=5433

# --- Build Configuration ---
# Set these to use alternative repositories/mirrors if default ones are slow or unreachable
#APT_MIRROR=http://mirrors.ubuntu.com/mirrors.txt
#CONDA_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/anaconda/cloud/
#CONDA_MIRROR=https://mirrors.sjtug.sjtu.edu.cn/anaconda/cloud/
#CONDA_MIRROR=https://software.rc.stanford.edu/anaconda/cloud/

